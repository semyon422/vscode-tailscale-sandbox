#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

mkdir -p code-home tailscale-state

ENV_UID="$(grep -E '^UID=' .env 2>/dev/null | head -n1 | cut -d= -f2- || true)"
ENV_GID="$(grep -E '^GID=' .env 2>/dev/null | head -n1 | cut -d= -f2- || true)"

if [[ -n "${ENV_UID}" && -n "${ENV_GID}" ]]; then
  chown "${ENV_UID}:${ENV_GID}" code-home
fi

docker compose down
docker compose up -d --build
docker compose ps
